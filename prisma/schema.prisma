generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  BOOKED
  CLOSED
}

enum IntegrationToolType {
  WEBHOOK
  API_CALL
}

enum IntegrationAuthType {
  NONE
  BEARER
  API_KEY
  BASIC
}

enum IntegrationHttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model User {
  id               String              @id @default(cuid())
  name             String
  email            String              @unique
  hashedPassword   String
  role             UserRole            @default(ADMIN)
  positionTitle    String?
  department       String?
  isActive         Boolean             @default(true)
  avatarUrl        String?
  lastLoginAt      DateTime?
  assignedLeads    ContactSubmission[] @relation("LeadOwner")
  authoredComments CrmComment[]        @relation("CrmCommentAuthor")
  createdAuditLogs AuditLog[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([role])
  @@index([isActive])
}

model Doctor {
  id              String        @id @default(cuid())
  slug            String        @unique
  nameAr          String
  nameEn          String?
  titleAr         String
  titleEn         String?
  specialtyAr     String
  specialtyEn     String?
  bioAr           String        @db.Text
  bioEn           String?       @db.Text
  photoUrl        String?
  coverImageUrl   String?
  education       Json?
  publications    Json?
  achievements    Json?
  languages       String[]
  yearsExperience Int?
  status          ContentStatus @default(DRAFT)
  isFeatured      Boolean       @default(false)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  services        Service[]     @relation("DoctorServices")
}

model Service {
  id                 String              @id @default(cuid())
  slug               String              @unique
  nameAr             String
  nameEn             String?
  excerptAr          String              @db.Text
  excerptEn          String?             @db.Text
  descriptionAr      String              @db.Text
  descriptionEn      String?             @db.Text
  coverImageUrl      String?
  categoryKey        String
  categoryId         String?
  seoTitleAr         String?
  seoTitleEn         String?
  seoDescriptionAr   String?             @db.Text
  seoDescriptionEn   String?             @db.Text
  status             ContentStatus       @default(DRAFT)
  isFeatured         Boolean             @default(false)
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  doctors            Doctor[]            @relation("DoctorServices")
  devices            Device[]            @relation("ServiceDevices")
  category           ServiceCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  contactSubmissions ContactSubmission[]
  webhooks           Webhook[]

  @@index([categoryId])
  @@index([categoryKey])
}

model ServiceCategory {
  id            String        @id @default(cuid())
  slug          String        @unique
  nameAr        String
  nameEn        String?
  descriptionAr String?       @db.Text
  descriptionEn String?       @db.Text
  status        ContentStatus @default(PUBLISHED)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  services      Service[]

  @@index([status])
  @@index([sortOrder])
}

model Device {
  id             String        @id @default(cuid())
  slug           String        @unique
  nameAr         String
  nameEn         String?
  excerptAr      String?       @db.Text
  excerptEn      String?       @db.Text
  descriptionAr  String        @db.Text
  descriptionEn  String?       @db.Text
  gallery        Json?
  specifications Json?
  certifications Json?
  status         ContentStatus @default(DRAFT)
  isFeatured     Boolean       @default(false)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  services       Service[]     @relation("ServiceDevices")
}

model GalleryItem {
  id                  String        @id @default(cuid())
  slug                String        @unique
  titleAr             String
  titleEn             String?
  beforeImageUrl      String
  afterImageUrl       String
  beforeImageAlt      String?
  afterImageAlt       String?
  categoryKey         String
  descriptionAr       String?       @db.Text
  descriptionEn       String?       @db.Text
  consentDocumentUrl  String?
  status              ContentStatus @default(DRAFT)
  sortOrder           Int           @default(0)
  initialSplitPercent Int           @default(50)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model JournalPost {
  id                  String        @id @default(cuid())
  slug                String        @unique
  titleAr             String
  titleEn             String?
  excerptAr           String        @db.Text
  excerptEn           String?       @db.Text
  bodyAr              Json
  bodyEn              Json?
  coverImageUrl       String
  categoryKey         String
  readingTimeLabel    String?
  relatedServiceSlugs String[]
  relatedDoctorSlugs  String[]
  status              ContentStatus @default(DRAFT)
  publishedAt         DateTime?
  sortOrder           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model ContactSubmission {
  id                String           @id @default(cuid())
  fullName          String
  phone             String
  email             String?
  message           String?          @db.Text
  preferredLanguage String           @default("ar")
  source            String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  ipAddress         String?
  country           String?
  referrerUrl       String?          @db.Text
  landingPageUrl    String?          @db.Text
  userAgent         String?          @db.Text
  status            SubmissionStatus @default(NEW)
  internalNotes     String?          @db.Text
  tags              String[]         @default([])
  webhookId         String?
  serviceId         String?
  assignedToId      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  service           Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedTo        User?            @relation("LeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)
  webhook           Webhook?         @relation(fields: [webhookId], references: [id], onDelete: SetNull)
  comments          CrmComment[]

  @@index([phone, createdAt])
}

model CrmComment {
  id           String            @id @default(cuid())
  submissionId String
  authorId     String?
  authorName   String?
  body         String            @db.Text
  createdAt    DateTime          @default(now())
  submission   ContactSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author       User?             @relation("CrmCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([createdAt])
}

model CustomPage {
  id              String        @id @default(cuid())
  slug            String        @unique
  titleAr         String
  titleEn         String?
  htmlContent     String        @db.Text
  seoTitle        String?
  seoDescription  String?       @db.Text
  metaTitle       String?
  metaDescription String?       @db.Text
  keywords        String[]      @default([])
  ogTitle         String?
  ogDescription   String?       @db.Text
  ogImage         String?
  seoSlug         String?
  hashtags        String[]      @default([])
  formConfig      Json?
  status          ContentStatus @default(DRAFT)
  noindex         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
}

model Webhook {
  id            String              @id @default(cuid())
  name          String
  token         String              @unique
  isActive      Boolean             @default(true)
  defaultStatus SubmissionStatus    @default(NEW)
  defaultTags   String[]            @default([])
  defaultSource String?
  serviceId     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  service       Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  events        WebhookEvent[]
  submissions   ContactSubmission[]

  @@index([token])
}

model WebhookEvent {
  id           String   @id @default(cuid())
  webhookId    String
  payload      Json
  statusCode   Int      @default(200)
  errorMessage String?  @db.Text
  ip           String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

model ErrorLog {
  id         String   @id @default(cuid())
  route      String?
  message    String   @db.Text
  stack      String?  @db.Text
  statusCode Int?
  payload    Json?
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  groupName String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
}

model AppLog {
  id        String   @id @default(cuid())
  level     String   @default("info")
  kind      String   @default("general")
  message   String   @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([kind])
  @@index([createdAt])
}

/// Integration tools the AI agent can call (outbound).
/// Distinct from `Webhook` (inbound lead-source).
model IntegrationTool {
  id                  String                @id @default(cuid())
  name                String                @unique
  description         String                @db.Text
  type                IntegrationToolType   @default(WEBHOOK)
  method              IntegrationHttpMethod @default(POST)
  url                 String                @db.Text
  headersJson         Json                  @default("[]")
  authType            IntegrationAuthType   @default(NONE)
  authConfigJson      Json?
  parametersJson      Json                  @default("[]")
  bodyTemplateJson    Json?
  responseMappingJson Json?
  aiInstructions      String?               @db.Text
  timeoutMs           Int                   @default(10000)
  isActive            Boolean               @default(true)
  lastTestStatus      String?
  lastTestAt          DateTime?
  lastError           String?               @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  logs                IntegrationToolLog[]

  @@index([isActive])
  @@index([type])
}

model IntegrationToolLog {
  id              String          @id @default(cuid())
  integrationId   String
  toolName        String
  status          String
  httpStatus      Int?
  requestPreview  Json?
  responsePreview Json?
  error           String?         @db.Text
  executionMs     Int             @default(0)
  createdAt       DateTime        @default(now())
  integration     IntegrationTool @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([createdAt])
}
