generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
  MEDICAL_DIRECTOR
  DOCTOR
  NURSE
  COORDINATOR
  RECEPTIONIST
  AUDITOR
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  BOOKED
  CLOSED
}

enum IntegrationToolType {
  WEBHOOK
  API_CALL
}

enum IntegrationAuthType {
  NONE
  BEARER
  API_KEY
  BASIC
}

enum IntegrationHttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

model User {
  id               String              @id @default(cuid())
  name             String
  email            String              @unique
  hashedPassword   String
  role             UserRole            @default(ADMIN)
  positionTitle    String?
  department       String?
  isActive         Boolean             @default(true)
  avatarUrl        String?
  lastLoginAt      DateTime?
  assignedLeads    ContactSubmission[] @relation("LeadOwner")
  authoredComments CrmComment[]        @relation("CrmCommentAuthor")
  createdAuditLogs AuditLog[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([role])
  @@index([isActive])
}

model Doctor {
  id              String                @id @default(cuid())
  slug            String                @unique
  nameAr          String
  nameEn          String?
  titleAr         String
  titleEn         String?
  specialtyAr     String
  specialtyEn     String?
  bioAr           String                @db.Text
  bioEn           String?               @db.Text
  photoUrl        String?
  coverImageUrl   String?
  education       Json?
  publications    Json?
  achievements    Json?
  languages       String[]
  yearsExperience Int?
  status          ContentStatus         @default(DRAFT)
  isFeatured      Boolean               @default(false)
  sortOrder       Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  services        Service[]             @relation("DoctorServices")
  procedures      Procedure[]           @relation("ProcedureDoctor")
  followUps       FollowUpAppointment[] @relation("AppointmentDoctor")
}

model Service {
  id                 String              @id @default(cuid())
  slug               String              @unique
  nameAr             String
  nameEn             String?
  excerptAr          String              @db.Text
  excerptEn          String?             @db.Text
  descriptionAr      String              @db.Text
  descriptionEn      String?             @db.Text
  coverImageUrl      String?
  categoryKey        String
  categoryId         String?
  seoTitleAr         String?
  seoTitleEn         String?
  seoDescriptionAr   String?             @db.Text
  seoDescriptionEn   String?             @db.Text
  status             ContentStatus       @default(DRAFT)
  isFeatured         Boolean             @default(false)
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  doctors            Doctor[]            @relation("DoctorServices")
  devices            Device[]            @relation("ServiceDevices")
  category           ServiceCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  contactSubmissions ContactSubmission[]
  webhooks           Webhook[]

  @@index([categoryId])
  @@index([categoryKey])
}

model ServiceCategory {
  id            String        @id @default(cuid())
  slug          String        @unique
  nameAr        String
  nameEn        String?
  descriptionAr String?       @db.Text
  descriptionEn String?       @db.Text
  status        ContentStatus @default(PUBLISHED)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  services      Service[]

  @@index([status])
  @@index([sortOrder])
}

model Device {
  id             String        @id @default(cuid())
  slug           String        @unique
  nameAr         String
  nameEn         String?
  excerptAr      String?       @db.Text
  excerptEn      String?       @db.Text
  descriptionAr  String        @db.Text
  descriptionEn  String?       @db.Text
  gallery        Json?
  specifications Json?
  certifications Json?
  status         ContentStatus @default(DRAFT)
  isFeatured     Boolean       @default(false)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  services       Service[]     @relation("ServiceDevices")
}

model GalleryItem {
  id                  String        @id @default(cuid())
  slug                String        @unique
  titleAr             String
  titleEn             String?
  beforeImageUrl      String
  afterImageUrl       String
  beforeImageAlt      String?
  afterImageAlt       String?
  categoryKey         String
  descriptionAr       String?       @db.Text
  descriptionEn       String?       @db.Text
  consentDocumentUrl  String?
  status              ContentStatus @default(DRAFT)
  sortOrder           Int           @default(0)
  initialSplitPercent Int           @default(50)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model JournalPost {
  id                  String        @id @default(cuid())
  slug                String        @unique
  titleAr             String
  titleEn             String?
  excerptAr           String        @db.Text
  excerptEn           String?       @db.Text
  bodyAr              Json
  bodyEn              Json?
  coverImageUrl       String
  categoryKey         String
  readingTimeLabel    String?
  relatedServiceSlugs String[]
  relatedDoctorSlugs  String[]
  status              ContentStatus @default(DRAFT)
  publishedAt         DateTime?
  sortOrder           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model ContactSubmission {
  id                String           @id @default(cuid())
  fullName          String
  phone             String
  email             String?
  message           String?          @db.Text
  preferredLanguage String           @default("ar")
  source            String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  ipAddress         String?
  country           String?
  referrerUrl       String?          @db.Text
  landingPageUrl    String?          @db.Text
  userAgent         String?          @db.Text
  status            SubmissionStatus @default(NEW)
  internalNotes     String?          @db.Text
  tags              String[]         @default([])
  webhookId         String?
  serviceId         String?
  assignedToId      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  service           Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedTo        User?            @relation("LeadOwner", fields: [assignedToId], references: [id], onDelete: SetNull)
  webhook           Webhook?         @relation(fields: [webhookId], references: [id], onDelete: SetNull)
  comments          CrmComment[]

  @@index([phone, createdAt])
  @@index([ipAddress])
}

model BlockedIp {
  id            String   @id @default(cuid())
  ipAddress     String   @unique
  reason        String?  @db.Text
  createdById   String?
  createdByName String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model CrmComment {
  id           String            @id @default(cuid())
  submissionId String
  authorId     String?
  authorName   String?
  body         String            @db.Text
  createdAt    DateTime          @default(now())
  submission   ContactSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author       User?             @relation("CrmCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([submissionId])
  @@index([createdAt])
}

model CustomPage {
  id                 String        @id @default(cuid())
  slug               String        @unique
  titleAr            String
  titleEn            String?
  htmlContent        String        @db.Text
  seoTitle           String?
  seoDescription     String?       @db.Text
  metaTitle          String?
  metaDescription    String?       @db.Text
  keywords           String[]      @default([])
  ogTitle            String?
  ogDescription      String?       @db.Text
  ogImage            String?
  seoSlug            String?
  hashtags           String[]      @default([])
  formConfig         Json?
  leadWebhookEnabled Boolean       @default(false)
  leadWebhookUrl     String?       @db.Text
  leadWebhookSecret  String?
  leadWebhookLabel   String?
  status             ContentStatus @default(DRAFT)
  noindex            Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status])
}

model Webhook {
  id            String              @id @default(cuid())
  name          String
  token         String              @unique
  isActive      Boolean             @default(true)
  defaultStatus SubmissionStatus    @default(NEW)
  defaultTags   String[]            @default([])
  defaultSource String?
  serviceId     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  service       Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  events        WebhookEvent[]
  submissions   ContactSubmission[]

  @@index([token])
}

model WebhookEvent {
  id           String   @id @default(cuid())
  webhookId    String
  payload      Json
  statusCode   Int      @default(200)
  errorMessage String?  @db.Text
  ip           String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

model ErrorLog {
  id         String   @id @default(cuid())
  route      String?
  message    String   @db.Text
  stack      String?  @db.Text
  statusCode Int?
  payload    Json?
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  groupName String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
}

model AppLog {
  id        String   @id @default(cuid())
  level     String   @default("info")
  kind      String   @default("general")
  message   String   @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([kind])
  @@index([createdAt])
}

/// Integration tools the AI agent can call (outbound).
/// Distinct from `Webhook` (inbound lead-source).
model IntegrationTool {
  id                  String                @id @default(cuid())
  name                String                @unique
  description         String                @db.Text
  type                IntegrationToolType   @default(WEBHOOK)
  method              IntegrationHttpMethod @default(POST)
  url                 String                @db.Text
  headersJson         Json                  @default("[]")
  authType            IntegrationAuthType   @default(NONE)
  authConfigJson      Json?
  parametersJson      Json                  @default("[]")
  bodyTemplateJson    Json?
  responseMappingJson Json?
  aiInstructions      String?               @db.Text
  timeoutMs           Int                   @default(10000)
  isActive            Boolean               @default(true)
  lastTestStatus      String?
  lastTestAt          DateTime?
  lastError           String?               @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  logs                IntegrationToolLog[]

  @@index([isActive])
  @@index([type])
}

model IntegrationToolLog {
  id              String          @id @default(cuid())
  integrationId   String
  toolName        String
  status          String
  httpStatus      Int?
  requestPreview  Json?
  responsePreview Json?
  error           String?         @db.Text
  executionMs     Int             @default(0)
  createdAt       DateTime        @default(now())
  integration     IntegrationTool @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([createdAt])
}

// ============================================================
// Rejuvera Patient Portal
// Patient records, procedures, instruction templates, portal
// auth, messaging, feedback, documents, notifications, audit.
// ============================================================

enum PatientAccountStatus {
  PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum PatientGender {
  MALE
  FEMALE
}

enum ProcedureStatus {
  DRAFT
  SCHEDULED
  COMPLETED
  POSTPONED
  CANCELLED
  FOLLOW_UP
}

enum TemplateStatus {
  DRAFT
  MEDICALLY_APPROVED
  ARCHIVED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  MISSED
  CANCELLED
}

enum MessageSenderType {
  PATIENT
  STAFF
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  CLOSED
}

enum FeedbackStatus {
  NEW
  REVIEWED
  CONTACTED
  CLOSED
}

enum ChecklistPhase {
  BEFORE_OPERATION
  OPERATION_DAY
  AFTER_OPERATION
  FOLLOW_UP
}

enum DocumentVisibility {
  STAFF_ONLY
  PATIENT_VISIBLE
}

enum PortalTokenPurpose {
  ACTIVATION
  RECOVERY
}

enum PortalActorType {
  STAFF
  PATIENT
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  SMS
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
  CANCELLED
}

model Patient {
  id                    String                   @id @default(uuid())
  fileNumber            String                   @unique
  fullNameAr            String
  fullNameEn            String?
  phone                 String
  email                 String?
  dateOfBirth           DateTime?
  gender                PatientGender?
  emergencyContactName  String?
  emergencyContactPhone String?
  accountStatus         PatientAccountStatus     @default(PENDING)
  preferredLanguage     String                   @default("ar")
  internalNotes         String?                  @db.Text
  archivedAt            DateTime?
  archivedById          String?
  archivedByName        String?
  createdById           String?
  createdByName         String?
  lastLoginAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  account               PatientAccount?
  procedures            Procedure[]
  appointments          FollowUpAppointment[]
  messages              PatientMessage[]
  feedback              PatientFeedback[]
  documents             PatientDocument[]
  notifications         PatientNotification[]
  activationTokens      PatientActivationToken[]
  sessions              PatientSession[]
  checklistItems        ProcedureChecklistItem[]

  @@index([phone])
  @@index([accountStatus])
  @@index([createdAt])
  @@index([archivedAt])
}

model PatientAccount {
  id                   String    @id @default(uuid())
  patientId            String    @unique
  loginIdentifier      String    @unique
  hashedPassword       String?
  mustChangePassword   Boolean   @default(true)
  phoneVerifiedAt      DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  activatedAt          DateTime?
  lastPasswordChangeAt DateTime?
  termsAcceptedAt      DateTime?
  privacyPolicyVersion String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  patient              Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientActivationToken {
  id            String             @id @default(uuid())
  patientId     String
  tokenHash     String             @unique
  otpHash       String?
  purpose       PortalTokenPurpose @default(ACTIVATION)
  expiresAt     DateTime
  usedAt        DateTime?
  attempts      Int                @default(0)
  createdById   String?
  createdByName String?
  createdAt     DateTime           @default(now())
  patient       Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([expiresAt])
}

model PatientSession {
  id         String    @id @default(uuid())
  patientId  String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?   @db.Text
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  patient    Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([expiresAt])
}

model ProcedureTemplate {
  id                     String         @id @default(uuid())
  nameAr                 String
  nameEn                 String?
  category               String
  preOperationContentAr  String?        @db.Text
  preOperationContentEn  String?        @db.Text
  operationDayContentAr  String?        @db.Text
  operationDayContentEn  String?        @db.Text
  postOperationContentAr String?        @db.Text
  postOperationContentEn String?        @db.Text
  warningSignsAr         String?        @db.Text
  warningSignsEn         String?        @db.Text
  followUpContentAr      String?        @db.Text
  followUpContentEn      String?        @db.Text
  checklistJson          Json?
  version                Int            @default(1)
  status                 TemplateStatus @default(DRAFT)
  parentTemplateId       String?
  approvedById           String?
  approvedByName         String?
  approvedAt             DateTime?
  createdById            String?
  createdByName          String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  procedures             Procedure[]

  @@index([status])
  @@index([category])
  @@index([parentTemplateId])
}

model Procedure {
  id                         String                   @id @default(uuid())
  patientId                  String
  procedureTemplateId        String?
  templateVersion            Int?
  customProcedureName        String?
  category                   String?
  doctorId                   String?
  surgeonName                String?
  procedureDate              DateTime?
  procedureTime              String?
  arrivalTime                String?
  location                   String?
  status                     ProcedureStatus          @default(DRAFT)
  preOperationInstructions   String?                  @db.Text
  operationDayInstructions   String?                  @db.Text
  postOperationInstructions  String?                  @db.Text
  warningSigns               String?                  @db.Text
  followUpInstructions       String?                  @db.Text
  privateStaffNotes          String?                  @db.Text
  patientVisibleNotes        String?                  @db.Text
  instructionsVersion        Int                      @default(1)
  instructionsPublishedAt    DateTime?
  instructionsAcknowledgedAt DateTime?
  acknowledgedVersion        Int?
  archivedAt                 DateTime?
  createdById                String?
  createdByName              String?
  updatedById                String?
  updatedByName              String?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  patient                    Patient                  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  template                   ProcedureTemplate?       @relation(fields: [procedureTemplateId], references: [id], onDelete: SetNull)
  doctor                     Doctor?                  @relation("ProcedureDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  appointments               FollowUpAppointment[]
  messages                   PatientMessage[]
  feedback                   PatientFeedback[]
  checklistItems             ProcedureChecklistItem[]
  documents                  PatientDocument[]

  @@index([patientId])
  @@index([status])
  @@index([procedureDate])
  @@index([doctorId])
  @@index([archivedAt])
}

model FollowUpAppointment {
  id                  String            @id @default(uuid())
  procedureId         String
  patientId           String
  appointmentDate     DateTime
  appointmentTime     String?
  appointmentType     String?
  doctorId            String?
  status              AppointmentStatus @default(SCHEDULED)
  notes               String?           @db.Text
  patientVisibleNotes String?           @db.Text
  reminderStatus      String            @default("pending")
  createdById         String?
  createdByName       String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  procedure           Procedure         @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  patient             Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor              Doctor?           @relation("AppointmentDoctor", fields: [doctorId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([procedureId])
  @@index([appointmentDate])
  @@index([status])
}

model PatientMessage {
  id              String            @id @default(uuid())
  patientId       String
  procedureId     String?
  parentMessageId String?
  senderType      MessageSenderType
  senderUserId    String?
  senderUserName  String?
  category        String
  message         String            @db.Text
  status          MessageStatus     @default(UNREAD)
  isUrgent        Boolean           @default(false)
  readAt          DateTime?
  repliedAt       DateTime?
  closedAt        DateTime?
  createdAt       DateTime          @default(now())
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedure       Procedure?        @relation(fields: [procedureId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([procedureId])
  @@index([status])
  @@index([parentMessageId])
  @@index([createdAt])
}

model PatientFeedback {
  id                  String         @id @default(uuid())
  patientId           String
  procedureId         String
  overallRating       Int
  careRating          Int?
  communicationRating Int?
  instructionsRating  Int?
  cleanlinessRating   Int?
  comment             String?        @db.Text
  permissionToContact Boolean        @default(false)
  permissionToPublish Boolean        @default(false)
  status              FeedbackStatus @default(NEW)
  internalNotes       String?        @db.Text
  submittedAt         DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  patient             Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedure           Procedure      @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  @@unique([procedureId, patientId])
  @@index([status])
  @@index([overallRating])
  @@index([submittedAt])
}

model ProcedureChecklistItem {
  id                 String         @id @default(uuid())
  procedureId        String
  patientId          String
  title              String
  description        String?        @db.Text
  phase              ChecklistPhase
  dueDate            DateTime?
  sortOrder          Int            @default(0)
  isRequired         Boolean        @default(false)
  patientCompletedAt DateTime?
  staffVerifiedAt    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  procedure          Procedure      @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  patient            Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([procedureId])
  @@index([patientId])
  @@index([phase])
}

model PatientDocument {
  id             String             @id @default(uuid())
  patientId      String
  procedureId    String?
  documentType   String
  title          String
  storageKey     String             @db.Text
  fileName       String?
  fileSize       Int?
  mimeType       String?
  visibility     DocumentVisibility @default(STAFF_ONLY)
  uploadedById   String?
  uploadedByName String?
  expiresAt      DateTime?
  archivedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  patient        Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  procedure      Procedure?         @relation(fields: [procedureId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([procedureId])
  @@index([visibility])
}

model PortalAuditLog {
  id         String          @id @default(uuid())
  actorType  PortalActorType
  actorId    String?
  actorName  String?
  action     String
  entityType String
  entityId   String?
  patientId  String?
  ipAddress  String?
  userAgent  String?         @db.Text
  changes    Json?
  createdAt  DateTime        @default(now())

  @@index([patientId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model PatientNotification {
  id           String              @id @default(uuid())
  patientId    String
  procedureId  String?
  event        String
  channel      NotificationChannel @default(IN_APP)
  title        String
  body         String              @db.Text
  status       NotificationStatus  @default(PENDING)
  scheduledFor DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  error        String?             @db.Text
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  patient      Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([status])
  @@index([event])
  @@index([scheduledFor])
}
