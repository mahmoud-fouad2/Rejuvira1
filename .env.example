# ===================================================================
# Rejuvera Center - environment configuration template
# ===================================================================
# Copy this file to `.env` for local development, or paste these keys
# into Render.com Environment for production. Do NOT commit `.env`.
# Every variable below is consumed at runtime by the Next.js app, the
# Prisma client, or the deploy pipeline. Defaults marked `OPTIONAL`
# can be left blank in non-production environments.
# ===================================================================

# Database (Neon Postgres)
# IMPORTANT: Replace HOST / USER / PASSWORD with real values from Neon.
# Never leave the literal hostname "HOST" - Render will fail with P1001.
# Pooled connection - used by the running app at request time.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
# Direct connection - used by `prisma migrate deploy`. Optional but
# recommended on Neon to bypass the pgbouncer pooler during migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth (v5 beta)
# Do not pin NEXTAUTH_URL/AUTH_URL. Auth.js should trust the request
# host so Render preview URLs and rejuvera.sa keep same-host login redirects.
AUTH_TRUST_HOST="true"
NEXTAUTH_URL=""
AUTH_URL=""
# 32+ byte random string - generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
AUTH_SECRET="replace-with-a-long-random-string"

# Canonical site URL (used by SEO, sitemap, robots, OG)
SITE_URL="https://rejuvera.sa"

# Cloudflare R2 (S3-compatible object storage)
# Account ID is the prefix used in the R2 S3 endpoint URL.
R2_ACCOUNT_ID="replace-with-cloudflare-account-id"
R2_ENDPOINT="https://replace-with-cloudflare-account-id.r2.cloudflarestorage.com"
R2_BUCKET="rejuvera"
# REQUIRED - generate inside Cloudflare R2 Manage R2 API Tokens.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# OPTIONAL - public CDN/custom-domain prefix for objects, e.g.
# https://cdn.rejuvera.sa. When set, uploads return public URLs
# instead of pre-signed ones.
R2_PUBLIC_BASE_URL=""

# Google reCAPTCHA v3 (rejuvera.sa + rejuvira1.onrender.com)
RECAPTCHA_SITE_KEY="replace-with-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="replace-with-recaptcha-secret-key"
# Public copy of the site key - required so the client script can
# render. Mirror of RECAPTCHA_SITE_KEY (Next.js inlines NEXT_PUBLIC_*).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="replace-with-recaptcha-site-key"
# Set to "1" only after the Google keys are recreated for all live domains.
RECAPTCHA_STRICT="0"

# Contact information (OPTIONAL - DB Settings overrides these)
# These envs only seed the very first request when the database
# Settings table is empty. The admin Settings UI is the source of truth.
CONTACT_PHONE_PRIMARY="0114999959"
CONTACT_PHONE_SECONDARY="9200 17403"
CONTACT_EMAIL_PRIMARY="info@rejuvera.sa"
CONTACT_EMAIL_SECONDARY="info@rejuvera.sa"

# SMTP email delivery for patient portal activation/recovery links.
# ---------------------------------------------------------------------------
# The admin's SMTP settings card (Settings → SMTP) surfaces what the runtime
# actually sees and can send a diagnostic email — use it before inviting real
# patients.
#
# Gmail: DO NOT use your Google account password. Create an App Password at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification)
# and paste the 16-character token as SMTP_PASS. That fixes the
# "535-5.7.8 Username and Password not accepted" (EAUTH) error.
#
# For business volume prefer a dedicated provider (Zoho Mail, Postmark, SES,
# Resend) — Gmail throttles heavily and eventually blocks bulk sends.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
# Explicit override. Defaults to true when SMTP_PORT is 465.
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""

# Header identity — what the patient sees as the sender.
MAIL_FROM_NAME="Rejuvera Center"
MAIL_FROM_EMAIL=""

# Legacy alias kept for older deployments — MAIL_FROM_EMAIL wins if both are set.
SMTP_FROM=""

# Google Maps embed (OPTIONAL - DB Settings overrides)
# Full embed URL (Maps Share Embed a map copy the iframe `src`).
GOOGLE_MAPS_EMBED_URL=""

# Render.com / runtime tweaks (OPTIONAL)
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
