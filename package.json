{
  "name": "rejuvera-center-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/sync-standalone-assets.mjs",
    "postinstall": "node scripts/render-migrate-recover.mjs",
    "start": "node scripts/run-standalone-server.mjs",
    "start:standalone": "node scripts/run-standalone-server.mjs",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:retry": "node scripts/render-migrate-deploy.mjs",
    "db:push": "prisma db push",
    "seed:admin": "node scripts/seed-admin.mjs",
    "seed:core": "node scripts/seed-core-content.mjs"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^6.8.2",
    "@tailwindcss/postcss": "^4",
    "bcryptjs": "^2.4.3",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.29",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "tailwindcss": "^4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "^6.8.2",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "postcss": "^8.5.14"
  }
}
